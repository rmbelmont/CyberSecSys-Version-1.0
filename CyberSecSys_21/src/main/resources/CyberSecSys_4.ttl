@prefix : <http://www.ppgi.uniriotec.br/CyberSecSys_1.0#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix CyberSecSys_1.0: <http://www.ppgi.unirio.br/CyberSecSys_1.0#> .
@base <http://www.ppgi.unirio.br/CyberSecSys_1.0#> .

<http://www.ppgi.unirio.br/CyberSecSys_1.0#> rdf:type owl:Ontology ;
                                              owl:imports <http://d3fend.mitre.org/ontologies/d3fend.owl> ;
                                              dc:description "Cybersecurity Management in Information Systems" ;
                                              owl:versionIRI "CyberSecSys_Version_1.0" ;
                                              owl:versionInfo 1.0 .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#versionIRI
owl:versionIRI rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.ppgi.unirio.br/ColaborativeSystemHasApi
<http://www.ppgi.unirio.br/ColaborativeSystemHasApi> rdf:type owl:ObjectProperty .


###  http://www.ppgi.unirio.br/ColaborativeSystemHasAttack
<http://www.ppgi.unirio.br/ColaborativeSystemHasAttack> rdf:type owl:ObjectProperty .


###  http://www.ppgi.unirio.br/ColaborativeSystemHasWeakness
<http://www.ppgi.unirio.br/ColaborativeSystemHasWeakness> rdf:type owl:ObjectProperty .


###  http://www.ppgi.unirio.br/CyberOhysicalSystemHasAttack
<http://www.ppgi.unirio.br/CyberOhysicalSystemHasAttack> rdf:type owl:ObjectProperty .


###  http://www.ppgi.unirio.br/CyberOhysicalSystemHasWeakness
<http://www.ppgi.unirio.br/CyberOhysicalSystemHasWeakness> rdf:type owl:ObjectProperty .


###  http://www.ppgi.unirio.br/CyberPhysicalSystemHasApi
<http://www.ppgi.unirio.br/CyberPhysicalSystemHasApi> rdf:type owl:ObjectProperty .


###  http://www.ppgi.unirio.br/IntelligentSystemHasApi
<http://www.ppgi.unirio.br/IntelligentSystemHasApi> rdf:type owl:ObjectProperty .


###  http://www.ppgi.unirio.br/IntelligentSystemHasAttack
<http://www.ppgi.unirio.br/IntelligentSystemHasAttack> rdf:type owl:ObjectProperty .


###  http://www.ppgi.unirio.br/IntelligentSystemHasWeakness
<http://www.ppgi.unirio.br/IntelligentSystemHasWeakness> rdf:type owl:ObjectProperty .


###  http://www.ppgi.unirio.br/SecurityHasColaborativeSystem
<http://www.ppgi.unirio.br/SecurityHasColaborativeSystem> rdf:type owl:ObjectProperty ;
                                                          rdfs:subPropertyOf owl:topObjectProperty ;
                                                          rdfs:domain :Collaborative_Systems_Component ;
                                                          rdfs:range [ rdf:type owl:Restriction ;
                                                                       owl:onProperty <http://www.ppgi.unirio.br/SecurityHasColaborativeSystem> ;
                                                                       owl:someValuesFrom :Approach
                                                                     ] ,
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty <http://www.ppgi.unirio.br/SecurityHasColaborativeSystem> ;
                                                                       owl:someValuesFrom :Component
                                                                     ] ,
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty <http://www.ppgi.unirio.br/SecurityHasColaborativeSystem> ;
                                                                       owl:someValuesFrom :PerformanceEvaluation
                                                                     ] .


###  http://www.ppgi.unirio.br/SystemOfSystensHasApi
<http://www.ppgi.unirio.br/SystemOfSystensHasApi> rdf:type owl:ObjectProperty ;
                                                  rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.ppgi.unirio.br/SystemOfSystensHasAttack
<http://www.ppgi.unirio.br/SystemOfSystensHasAttack> rdf:type owl:ObjectProperty .


###  http://www.ppgi.unirio.br/SystemOfSystensHasWeakness
<http://www.ppgi.unirio.br/SystemOfSystensHasWeakness> rdf:type owl:ObjectProperty .


###  http://www.ppgi.uniriotec.br/CyberSecSys_1.0#SecurityHasCyberPhysicalSystem
:SecurityHasCyberPhysicalSystem rdf:type owl:ObjectProperty ;
                                rdfs:domain :CyberPhysicalSystem_Component ;
                                rdfs:range [ rdf:type owl:Restriction ;
                                             owl:onProperty :SecurityHasCyberPhysicalSystem ;
                                             owl:someValuesFrom :Approach
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :SecurityHasCyberPhysicalSystem ;
                                             owl:someValuesFrom :Component
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :SecurityHasCyberPhysicalSystem ;
                                             owl:someValuesFrom :PerformanceEvaluation
                                           ] .


###  http://www.ppgi.uniriotec.br/CyberSecSys_1.0#SecurityHasIntelligentSystem
:SecurityHasIntelligentSystem rdf:type owl:ObjectProperty ;
                              rdfs:domain :IntelligentSystem_Component ;
                              rdfs:range [ rdf:type owl:Restriction ;
                                           owl:onProperty :SecurityHasIntelligentSystem ;
                                           owl:someValuesFrom :Approach
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :SecurityHasIntelligentSystem ;
                                           owl:someValuesFrom :Component
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :SecurityHasIntelligentSystem ;
                                           owl:someValuesFrom :PerformanceEvaluation
                                         ] .


###  http://www.ppgi.uniriotec.br/CyberSecSys_1.0#SecurityHasSystem
:SecurityHasSystem rdf:type owl:ObjectProperty ;
                   rdfs:domain :CyberPhysicalSystem_Component ,
                               :IntelligentSystem_Component ,
                               :SystemOfSystems_Component ;
                   rdfs:range [ rdf:type owl:Restriction ;
                                owl:onProperty :SecurityHasSystem ;
                                owl:someValuesFrom :CyberPhysicalSystem_Component
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :SecurityHasSystem ;
                                owl:someValuesFrom :IntelligentSystem_Component
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :SecurityHasSystem ;
                                owl:someValuesFrom :SystemOfSystems_Component
                              ] .


###  http://www.ppgi.uniriotec.br/CyberSecSys_1.0#SecurityHasSystemOfSystems
:SecurityHasSystemOfSystems rdf:type owl:ObjectProperty ;
                            rdfs:domain :SystemOfSystems_Component ;
                            rdfs:range [ rdf:type owl:Restriction ;
                                         owl:onProperty :SecurityHasSystemOfSystems ;
                                         owl:someValuesFrom :Approach
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :SecurityHasSystemOfSystems ;
                                         owl:someValuesFrom :Component
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :SecurityHasSystemOfSystems ;
                                         owl:someValuesFrom :PerformanceEvaluation
                                       ] .


#################################################################
#    Classes
#################################################################

###  http://www.ppgi.uniriotec.br/CyberSecSys_1.0#Approach
:Approach rdf:type owl:Class ;
          rdfs:subClassOf :Security_Component .


###  http://www.ppgi.uniriotec.br/CyberSecSys_1.0#Automation_Tool
:Automation_Tool rdf:type owl:Class ;
                 rdfs:subClassOf :Technology_Approach .


###  http://www.ppgi.uniriotec.br/CyberSecSys_1.0#Collaborative_Systems_Component
:Collaborative_Systems_Component rdf:type owl:Class .


