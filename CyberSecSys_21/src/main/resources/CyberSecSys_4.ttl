###  http://www.ppgi.unirio.br/CWE-664
<http://www.ppgi.unirio.br/CWE-664> rdf:type owl:NamedIndividual ,
                                             <http://d3fend.mitre.org/ontologies/d3fend.owl#CWE-435> ,
                                             <http://d3fend.mitre.org/ontologies/d3fend.owl#CWE-664> ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://www.ppgi.unirio.br/ColaborativeSystemHasWeakness> ;
                                               owl:someValuesFrom <http://d3fend.mitre.org/ontologies/d3fend.owl#CWE-664>
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://www.ppgi.unirio.br/CyberOhysicalSystemHasWeakness> ;
                                               owl:someValuesFrom <http://d3fend.mitre.org/ontologies/d3fend.owl#CWE-664>
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://www.ppgi.unirio.br/IntelligentSystemHasWeakness> ;
                                               owl:someValuesFrom <http://d3fend.mitre.org/ontologies/d3fend.owl#CWE-664>
                                             ] ,
